{
    "name": "aeliot/yaml-token",
    "type": "library",
    "description": "Tokenizer of YAML",
    "license": "MIT",
    "authors": [
        {
            "name": "Anatoliy Melnikov",
            "email": "5785276@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "keywords": [
        "YAML",
        "YAML Parser",
        "YAML Tokenizer",
        "Tokenizer"
    ],
    "autoload": {
        "psr-4": {
            "Aeliot\\YamlToken\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aeliot\\YamlToken\\Test\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/*": true
        },
        "sort-packages": true
    },
    "require": {
        "php": "^8.2"
    },
    "support": {
        "issues": "https://github.com/Aeliot-Tm/yaml-token/issues"
    }
}
